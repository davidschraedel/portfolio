---
import { Image } from "astro:assets";

import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const mediaLink = project.videoUrl ?? project.demoUrl;
---

<article class="overflow-hidden rounded-xl bg-off-white/80 ring-1 ring-sepia/25 dark:bg-dim-surface dark:ring-dim-muted">
  <div class="flex flex-col gap-4">
    <div class="order-first">
      {
        mediaLink ? (
          <a
            href={mediaLink}
            target="_blank"
            rel="noopener noreferrer"
            class="block overflow-hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sepia"
            aria-label={`${project.name} demo preview`}
          >
            <Image
              src={project.previewImage}
              alt={project.previewAlt}
              widths={[300, 400, 500]}
              sizes="(max-width: 768px) 100vw, 400px"
              class="h-auto max-h-48 w-full object-cover opacity-80 transition-opacity hover:opacity-95"
            />
          </a>
        ) : (
          <Image
            src={project.previewImage}
            alt={project.previewAlt}
            widths={[300, 400, 500]}
            sizes="(max-width: 768px) 100vw, 400px"
            class="h-auto max-h-48 w-full object-cover opacity-80"
          />
        )
      }
    </div>

    <div class="px-4 pb-5">
      <h3 class="text-xl font-semibold text-dark-moss">{project.name}</h3>

      <dl class="mt-4 space-y-3 text-base text-interior-designer dark:text-dim-text-muted">
        <div>
          <dt class="sr-only">Problem</dt>
          <dd>
            <span class="font-medium text-dark-moss">Problem ·</span>{" "}
            {project.objective}
          </dd>
        </div>
        <div>
          <dt class="sr-only">Solution</dt>
          <dd>
            <span class="font-medium text-dark-moss">Solution ·</span>{" "}
            {project.tradeOff}
          </dd>
        </div>
      </dl>

      <ul class="mt-4 flex flex-wrap gap-2" aria-label={`${project.name} tech stack`}>
        {
          project.stack.map((tag) => (
            <li class="rounded-full bg-skin/50 px-3 py-1 text-xs text-dark-moss dark:bg-dim-muted dark:text-dark-moss">
              {tag}
            </li>
          ))
        }
      </ul>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          project.demoUrl && (
            <a
              href={project.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-soft btn-soft-default"
            >
              Live demo
            </a>
          )
        }
        {
          project.githubUrl && (
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-soft btn-github"
            >
              GitHub
            </a>
          )
        }
        <!-- <a
          href={`${import.meta.env.BASE_URL}projects/${project.slug}/`}
          class="btn btn-soft btn-soft-default"
        >
          Read more...
        </a> -->
      </div>
    </div>
  </div>
</article>
