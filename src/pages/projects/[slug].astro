---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import CaseStudyTldr from "../../components/CaseStudyTldr.astro";
import MyRole from "../../components/MyRole.astro";
import ProductionThinking from "../../components/ProductionThinking.astro";
import { getProjectBySlug } from "../../data/projects";

export async function getStaticPaths() {
  const entries = await getCollection("projects");

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const project = getProjectBySlug(entry.id);

if (!project) {
  throw new Error(`No project metadata found for case study slug "${entry.id}".`);
}

const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} — Case study`}
  description={entry.data.problem}
>
  <article class="mx-auto max-w-3xl">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="text-sepia underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sepia"
      >
        Home
      </a>
      <span class="mx-2 text-interior-designer/60" aria-hidden="true">/</span>
      <span class="text-interior-designer dark:text-dim-text-muted">Case study</span>
    </nav>

    <header>
      <h1 class="text-3xl font-semibold text-dark-moss sm:text-4xl">{entry.data.title}</h1>

      <div class="mt-6 overflow-hidden rounded-xl ring-1 ring-sepia/25 dark:ring-dim-muted">
        <Image
          src={project.previewImage}
          alt={project.previewAlt}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, 720px"
          class="h-auto w-full object-cover"
        />
      </div>
    </header>

    <div class="mt-8">
      <CaseStudyTldr
        problem={entry.data.problem}
        keyDecision={entry.data.keyDecision}
        outcome={entry.data.outcome}
      />
    </div>

    <div
      class="prose-case-study mt-10 space-y-6 text-base leading-relaxed text-interior-designer dark:text-dim-text-muted [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:text-dark-moss [&_h2:first-child]:mt-0 sm:[&_h2]:text-2xl"
    >
      <Content />
    </div>

    <ProductionThinking productionThinking={entry.data.productionThinking} />

    {
      entry.data.myRole && (
        <MyRole
          contributions={entry.data.myRole.contributions}
          notMyWork={entry.data.myRole.notMyWork}
        />
      )
    }

    <footer class="mt-12 flex flex-wrap gap-3 border-t border-sepia/20 pt-8 dark:border-dim-muted">
      {
        project.demoUrl && (
          <a
            href={project.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-soft btn-soft-default"
          >
            Live demo
          </a>
        )
      }
      {
        project.githubUrl && (
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-soft btn-github"
          >
            GitHub
          </a>
        )
      }
      <a href={`${import.meta.env.BASE_URL}#projects`} class="btn btn-soft btn-soft-default">
        All projects
      </a>
    </footer>
  </article>
</BaseLayout>
