---
import { Image } from "astro:assets";

import headshot from "../assets/headshot.svg";
import { site } from "../data/site";
---

<div class="brand-gradient px-4 pb-8 pt-10">
  <Image
    src={headshot}
    alt="Portrait of David Schraedel"
    class="mx-auto w-48 max-w-[60%] rounded-full md:w-56 lg:w-64"
    width={320}
    height={320}
    loading="eager"
  />
</div>

<div class="px-4 pb-4 pt-8 text-center sm:px-8">
  <p class="text-5xl font-medium text-sepia dark:text-dim-highlight">{site.name}</p>
  <h1
    class="mx-auto mt-3 max-w-4xl text-2xl font-semibold leading-snug text-dark-moss sm:text-2xl"
  >
    {site.hero.contrastLead}
  </h1>
  <p
    class="mx-auto mt-4 max-w-3xl text-base leading-relaxed text-interior-designer dark:text-dim-text-muted"
  >
    {site.hero.professionalSentence}
  </p>

  <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:flex-wrap sm:gap-4">
    <a href={site.resumePath} target="_blank" class="btn btn-soft btn-soft-default">Resume</a>
    <a href={`mailto:${site.email}`} class="btn btn-soft btn-soft-default">Email</a>
    <a
      href={site.linkedInUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-soft btn-linkedin"
    >
      LinkedIn
    </a>
    <a
      href={site.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-soft btn-github"
    >
      GitHub
    </a>
  </div>
</div>
