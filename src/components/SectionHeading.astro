---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<div class="mb-8 text-center">
  <h2
    id={id}
    class="text-2xl font-semibold text-dark-moss sm:text-3xl"
  >
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 text-base text-interior-designer dark:text-dim-text-muted">
      {subtitle}
    </p>
  )}
</div>
