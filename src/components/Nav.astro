<nav aria-label="Main" class="pb-6 pt-2">
  <ul class="mx-auto flex flex-wrap justify-center gap-6 sm:gap-8">
    <li>
      <a href="#about" class="nav-link">About</a>
    </li>
    <li>
      <a href="#projects" class="nav-link">Featured projects</a>
    </li>
  </ul>
</nav>

<script>
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('nav[aria-label="Main"] a[href^="#"]');

  function updateActive() {
    const hash = window.location.hash;
    navLinks.forEach((link) => {
      link.setAttribute("aria-current", link.getAttribute("href") === hash ? "page" : "false");
    });
  }

  updateActive();
  window.addEventListener("hashchange", updateActive);
</script>
