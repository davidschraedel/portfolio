---
import { Image } from "astro:assets";

import type { Project } from "../data/projects";

interface Props {
  project: Project;
  variant: "flagship" | "compact";
}

const { project, variant } = Astro.props;

const mediaLink = project.videoUrl ?? project.demoUrl;
const isFlagship = variant === "flagship";

const imageSizes = isFlagship
  ? "(max-width: 768px) 100vw, 720px"
  : "(max-width: 768px) 100vw, 400px";
---

<article
  class:list={[
    "overflow-hidden rounded-xl ring-1 ring-sepia/25 dark:ring-dim-muted",
    isFlagship ? "bg-off-white dark:bg-dim-elevated" : "bg-off-white/80 dark:bg-dim-surface",
  ]}
>
  <div
    class:list={[
      isFlagship ? "grid gap-6 md:grid-cols-2 md:gap-8" : "flex flex-col gap-4",
    ]}
  >
    <div class:list={[isFlagship ? "" : "order-first"]}>
      {
        mediaLink ? (
          <a
            href={mediaLink}
            target="_blank"
            rel="noopener noreferrer"
            class="block overflow-hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sepia"
            aria-label={`${project.name} demo preview`}
          >
            <Image
              src={project.previewImage}
              alt={project.previewAlt}
              widths={isFlagship ? [400, 600, 800] : [300, 400, 500]}
              sizes={imageSizes}
              class:list={[
                "h-auto w-full object-cover transition-opacity hover:opacity-95",
                isFlagship ? "max-h-80 md:max-h-none" : "max-h-48",
              ]}
            />
          </a>
        ) : (
          <Image
            src={project.previewImage}
            alt={project.previewAlt}
            widths={isFlagship ? [400, 600, 800] : [300, 400, 500]}
            sizes={imageSizes}
            class:list={[
              "h-auto w-full object-cover",
              isFlagship ? "max-h-80 md:max-h-none" : "max-h-48",
            ]}
          />
        )
      }
    </div>

    <div class:list={[isFlagship ? "flex flex-col justify-center p-6 md:p-8" : "px-4 pb-5"]}>
      <h3
        class:list={[
          "font-semibold text-dark-moss",
          isFlagship ? "text-2xl" : "text-xl",
        ]}
      >
        {project.name}
        
      </h3>

      <dl class="mt-4 space-y-3 text-base text-interior-designer dark:text-dim-text-muted">
        <div>
          <dt class="sr-only">Problem</dt>
          <dd>
            <span class="font-medium text-dark-moss">Problem ·</span>{" "}
            {project.problem}
          </dd>
        </div>
        <div>
          <dt class="sr-only">Key decision</dt>
          <dd>
            <span class="font-medium text-dark-moss">Decision ·</span>{" "}
            {project.keyDecision}
          </dd>
        </div>
        <div>
          <dt class="sr-only">Outcome</dt>
          <dd>
            <span class="font-medium text-dark-moss">Outcome ·</span>{" "}
            {project.outcome}
          </dd>
        </div>
      </dl>

      <ul class="mt-4 flex flex-wrap gap-2" aria-label={`${project.name} tech stack`}>
        {
          project.stack.map((tag) => (
            <li class="rounded-full bg-skin/50 px-3 py-1 text-sm text-dark-moss dark:bg-dim-muted dark:text-dark-moss">
              {tag}
            </li>
          ))
        }
      </ul>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          project.demoUrl && (
            <a
              href={project.demoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-soft btn-soft-default"
            >
              Live demo
            </a>
          )
        }
        {
          project.githubUrl && (
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-soft btn-github"
            >
              GitHub
            </a>
          )
        }
      </div>
    </div>
  </div>
</article>
