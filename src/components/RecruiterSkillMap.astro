---
import { projects } from "../data/projects";
import { site } from "../data/site";

const projectById = new Map(projects.map((project) => [project.id, project.name]));
---

<ul class="space-y-3 text-base text-interior-designer dark:text-gray-300">
  {
    site.skillMap.map((entry) => {
      const projectName = projectById.get(entry.startWith) ?? entry.startWith;
      return (
        <li class="rounded-lg bg-off-white px-4 py-3 ring-1 ring-sepia/20 dark:bg-gray-800 dark:ring-gray-700">
          <span class="font-medium text-dark-moss dark:text-off-white">
            Hiring for {entry.hiringFor}
          </span>
          <span aria-hidden="true"> → </span>
          <span>Start with {projectName}</span>
        </li>
      );
    })
  }
</ul>
