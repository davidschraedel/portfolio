---
import { Image } from "astro:assets";

import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.name} — More`}
  description={project.objective}
>
  <article class="mx-auto max-w-3xl">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm">
      <a
        href={`${import.meta.env.BASE_URL}`}
        class="nav-link text-sm"
      >
        Home
      </a>
      <span class="mx-2 text-interior-designer/60" aria-hidden="true">/</span>
      <span class="text-interior-designer dark:text-dim-text-muted">{project.name}</span>
    </nav>

    <header>
      <h1 class="text-3xl font-semibold text-dark-moss sm:text-4xl">{project.name}</h1>

      <div class="mt-6 overflow-hidden rounded-xl ring-1 ring-sepia/25 dark:ring-dim-muted">
        <Image
          src={project.previewImage}
          alt={project.previewAlt}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, 720px"
          class="h-auto w-full object-cover"
        />
      </div>
    </header>

    <div class="mt-10 rounded-xl border border-sepia/20 bg-off-white/60 px-6 py-8 text-center dark:border-dim-muted dark:bg-dim-surface">
      <p class="text-lg font-medium text-dark-moss">Coming soon</p>
      <p class="mt-2 text-base text-interior-designer dark:text-dim-text-muted">
        More detail on this project is in the works.
      </p>
    </div>

    <footer class="mt-12 flex flex-wrap gap-3 border-t border-sepia/20 pt-8 dark:border-dim-muted">
      {
        project.demoUrl && (
          <a
            href={project.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-soft btn-soft-default"
          >
            Live demo
          </a>
        )
      }
      {
        project.githubUrl && (
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-soft btn-github"
          >
            GitHub
          </a>
        )
      }
      <a href={`${import.meta.env.BASE_URL}projects`} class="btn btn-soft btn-soft-default">
        All projects
      </a>
    </footer>
  </article>
</BaseLayout>
