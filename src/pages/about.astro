---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

import profile from "../data/profile.json";
---

<BaseLayout title="About — David Schraedel" description="About David Schraedel.">
  <section id="about" aria-labelledby="about-heading" class="scroll-mt-8">
    <SectionHeading id="about-heading" title={profile.about.heading} />

    <div class="mx-auto max-w-2xl space-y-5 text-base leading-relaxed text-interior-designer dark:text-dim-text-muted">
      {profile.about.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </section>

  <section id="timeline" aria-labelledby="timeline-heading" class="mt-16 scroll-mt-8">
    <SectionHeading id="timeline-heading" title="Timeline" />

    <ol class="mx-auto max-w-2xl space-y-6">
      {profile.timeline.map((entry) => (
        <li class="flex gap-4">
          <span class="mt-1 w-16 shrink-0 text-sm text-sepia dark:text-dim-highlight">
            {(entry.start ?? "").slice(0, 4)}
          </span>
          <p class="text-base leading-relaxed text-interior-designer dark:text-dim-text-muted">
            {entry.label}
          </p>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
