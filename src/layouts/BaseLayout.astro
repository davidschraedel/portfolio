---
import "../styles/global.css";

import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — Full-stack engineer portfolio`,
  description = site.hero.outcomeStatement,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="bg-off-white dark:bg-olive-950 text-dark-moss antialiased">
    <div class="m-6 my-7 overflow-x-clip sm:m-10 md:m-20 md:my-10">
      <div class="overflow-hidden rounded-lg shadow-md">
        <header class="bg-off-white text-center dark:bg-olive-950 dark:text-off-white">
          <slot name="hero" />
          <Nav />
        </header>

        <main
          class="  bg-off-white px-4 py-10  dark:bg-olive-950 dark:text-off-white sm:px-12 md:px-20 lg:px-32 xl:px-48"
        >
          <slot />
        </main>

        <Footer />
      </div>
    </div>
  </body>
</html>
