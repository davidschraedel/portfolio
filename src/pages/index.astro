---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";

const flagship = projects.find((project) => project.isFlagship);
const compactProjects = projects.filter((project) => project.featured && !project.isFlagship);

if (!flagship) {
  throw new Error("Exactly one flagship project is required.");
}
---

<BaseLayout
  title={`${site.name} — ${site.hero.roleHeadline}`}
  description={site.hero.outcomeStatement}
>
  <Hero slot="hero" />

  <section id="about" aria-labelledby="about-heading" class="scroll-mt-8">
    <SectionHeading
      id="about-heading"
      title="About"
      subtitle="Background and what I'm looking for."
    />
    <div class="mx-auto max-w-2xl space-y-4 text-base leading-relaxed text-interior-designer dark:text-dim-text-muted">
      {site.about.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  <section id="projects" aria-labelledby="projects-heading" class="mt-16 scroll-mt-8">
    <SectionHeading
      id="projects-heading"
      title="Featured projects"
      subtitle="Check out some of my projects I am proud of and enjoyed."
    />

    <div class="space-y-10">
      <ProjectShowcase project={flagship} variant="flagship" />

      <div class="grid gap-8 md:grid-cols-2">
        {
          compactProjects.map((project) => (
            <ProjectShowcase project={project} variant="compact" />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
