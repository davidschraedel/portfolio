---
import { Image } from "astro:assets";

import headshot from "../assets/headshot.svg";
import { site } from "../data/site";

const ctaClass =
  "inline-flex min-h-11 items-center justify-center rounded-md px-5 py-2.5 text-base font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sepia";
---

<div
  class="bg-gradient-to-tr from-yellow-950 to-indigo-200 px-4 pb-8 pt-10 dark:from-indigo-200 dark:to-yellow-950"
>
  <Image
    src={headshot}
    alt="Portrait of David Schraedel"
    class="mx-auto w-48 max-w-[60%] rounded-full md:w-56 lg:w-64"
    width={320}
    height={320}
    loading="eager"
  />
</div>

<div class="px-4 pb-4 pt-8 text-center sm:px-8">
  <p class="text-lg font-medium text-sepia dark:text-skin">{site.name}</p>
  <h1
    class="mx-auto mt-3 max-w-3xl text-2xl font-semibold leading-snug text-dark-moss dark:text-off-white sm:text-3xl"
  >
    {site.hero.roleHeadline}
  </h1>
  <p
    class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-interior-designer dark:text-gray-300"
  >
    {site.hero.outcomeStatement}
  </p>
  <p class="mx-auto mt-3 max-w-2xl text-base text-interior-designer/90 dark:text-gray-400">
    {site.hero.positioningLine}
  </p>

  <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
    <a
      href="#projects"
      class:list={[
        ctaClass,
        "bg-dark-moss text-off-white hover:bg-interior-designer dark:bg-indigo-900 dark:hover:bg-indigo-800",
      ]}
    >
      Featured projects
    </a>
    <a
      href={site.resumePath}
      class:list={[
        ctaClass,
        "bg-skin text-dark-moss ring-1 ring-sepia/30 hover:bg-skin/80 dark:bg-gray-800 dark:text-off-white dark:ring-gray-600 dark:hover:bg-gray-700",
      ]}
    >
      Download resume
    </a>
  </div>
</div>
