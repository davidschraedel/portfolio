---
import { site } from "../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="rounded-b-4xl brand-gradient px-4 pb-8 pt-6 text-center">
  <ul class="mx-auto my-8 flex max-w-xs flex-col items-center gap-3 sm:max-w-none sm:flex-row sm:justify-center sm:gap-4">
    <li>
      <a href={site.resumePath} target="_blank" class="btn btn-soft-default btn-footer">Resume</a>
    </li>
    
    <li>
      <a
        href={site.linkedInUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-footer btn-linkedin"
      >
        LinkedIn
      </a>
    </li>
    <li>
      <a
        href={site.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-footer btn-github"
      >
        GitHub
      </a>
    </li>
    <li>
      <a
        href={site.substackUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-footer btn-substack"
      >
        Substack
      </a>
    </li>
    <li>
      <a href={`mailto:${site.email}`} class="btn btn-soft-default btn-footer btn-gmail">Email</a>
    </li>
  </ul>

  <p class="pb-6 pt-2 text-sm text-white mix-blend-soft-light">
    © {currentYear} {site.name}
  </p>
</footer>
